{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "paplay ~/.claude/songs/duolingo-correct.mp3 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python -c \"from src.main import app\")",
      "Bash(pnpm test:*)",
      "Bash(pytest -v)"
    ]
  },
  "includeCoAuthoredBy": false
}
